# EditorConfig is awesome: https://editorconfig.org

# It's a top-most EditorConfig file
root = true

# All files
[*]
# Ident with 2 spaces
indent_style = space
indent_size = 2
# Unix-style newlines
end_of_line = lf
# UTF-8
charset = utf-8
# Remove any whitespace characters at the end of the line
trim_trailing_whitespace = true
# Newline ending every file
insert_final_newline = true

# Markdown
[*.{md,markdown}]
# Markdown files can have trailing whitespaces.
trim_trailing_whitespace = false
