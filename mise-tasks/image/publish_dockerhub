#!/usr/bin/env bash
# MISE description="Tag and push dogowaiter image to Docker Hub (assumes already logged in)"
set -eEo pipefail
IMAGE_TAG="${IMAGE_TAG:-latest}"
REGISTRY_OWNER="${REGISTRY_OWNER:?REGISTRY_OWNER must be set}"
# Docker Hub requires lowercase image names
OWNER_LC="$(echo "$REGISTRY_OWNER" | tr '[:upper:]' '[:lower:]')"
IMAGE="${OWNER_LC}/dogowaiter:${IMAGE_TAG}"
docker tag dogowaiter "$IMAGE"
docker push "$IMAGE"
